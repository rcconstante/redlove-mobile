{
  "expo": {
    "name": "RedLove",
    "slug": "redlove",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "redlove",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.redlovetoday.app",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow RedLove to use your camera for video calls and video clips.",
        "NSMicrophoneUsageDescription": "Allow RedLove to use your microphone for voice calls, video calls, voice notes, and video clips.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bitcode": false
    },
    "android": {
      "package": "com.redlovetoday.app",
      "versionCode": 2,
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#13051f",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#13051f",
          "android": {
            "image": "./assets/images/applogo.png",
            "imageWidth": 180
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow RedLove to access your photos so you can upload profile pictures.",
          "cameraPermission": "Allow RedLove to use your camera so you can take a profile picture."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow RedLove to use your camera for video calls and video clips.",
          "microphonePermission": "Allow RedLove to use your microphone for video clips.",
          "recordAudioAndroid": true
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow RedLove to use your camera for video calls.",
          "microphonePermission": "Allow RedLove to use your microphone for voice and video calls."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow RedLove to use your microphone for voice calls, video calls, and voice notes."
        }
      ],
      "expo-asset",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2bca57a9-6e72-4bda-991d-530660c3f7d0"
      }
    }
  }
}
